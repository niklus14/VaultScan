# Cloud Assistant (optional — for AI summaries / chat / rich reports)
# Prefer product Settings UI for AWS credentials; this file is for local/server defaults only.
GROK_API_KEY=
GROK_MODEL=grok-3-mini
GROK_BASE_URL=https://api.x.ai/v1

# Default AWS target (overridden by Settings → Cloud Connection in the UI)
AWS_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/VaultScan-ReadOnly
AWS_EXTERNAL_ID=
AWS_REGION=us-east-1
AWS_SESSION_NAME=VaultScanCSPM

# Optional base keys for sts:AssumeRole (or configure entirely in the UI)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional override for built-in alert sender (defaults ship in config for demos)
# VAULTSCAN_GMAIL_ADDRESS=Vaultscan.company@gmail.com
# VAULTSCAN_GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# VAULTSCAN_FROM_NAME=VaultScan Company

# Login (defaults: admin / vaultscan  and  vaultscan / vaultscan)
# VAULTSCAN_AUTH_USER=admin
# VAULTSCAN_AUTH_PASSWORD=vaultscan

