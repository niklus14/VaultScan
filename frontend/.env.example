# ─── VaultScan frontend (Next.js / Vercel) ───────────────────────────────────
# Copy to .env.local for local dev, or set in Vercel → Project → Settings → Environment Variables.

# Server-side only: where Next.js rewrites /api/* (used by next.config.ts)
# Local backend:
VAULTSCAN_API_ORIGIN=http://127.0.0.1:8000
# Production example (deployed FastAPI / Railway / Render / Fly / EC2):
# VAULTSCAN_API_ORIGIN=https://your-vaultscan-api.example.com

# Optional client override. Leave empty so the browser calls same-origin /api/*
# (proxied by rewrites). Set only if the UI must talk to the API directly (CORS).
# NEXT_PUBLIC_API_BASE=

# Public site URL (Open Graph / metadata). Vercel sets VERCEL_URL automatically;
# you can override for a custom domain.
# NEXT_PUBLIC_SITE_URL=https://vaultscan.vercel.app
